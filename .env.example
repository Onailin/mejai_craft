# Supabase PostgreSQL
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Auth.js (local dev only — do NOT copy NEXTAUTH_URL to Vercel)
AUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Vercel / production checklist:
# - Set AUTH_SECRET (openssl rand -base64 32) in Vercel Environment Variables
# - REQUIRED for deploy + runtime: DATABASE_URL and DIRECT_URL (Supabase → Settings → Database)
#   Apply to Production AND Preview so `npm run build` can read content during static generation
# - Set SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY for image uploads
# - Optional: NEXT_PUBLIC_SITE_URL="https://mejaicrafts.com" (for SEO og:image absolute URLs)
# - Do NOT set NEXTAUTH_URL on Vercel (trustHost infers https://mejaicrafts.com)
# - Run db:setup once against production DB to create admin user
# - Run npm run db:sync-static to seed static content and upload /images/* + /uploads/* to Supabase Storage

# Initial admin (used by seed only)
ADMIN_EMAIL="admin@mejaicrafts.com"
ADMIN_PASSWORD="change-me-strong-password"

# Supabase Storage (server-side only)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
SUPABASE_STORAGE_BUCKET="mejai-assets"

# DeepL API (server-side only)
DEEPL_API_KEY="your-deepl-api-key"
